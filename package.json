{
    "name": "secure-file-share",
    "private": true,
    "workspaces": [
        "backend",
        "frontend"
    ],
    "scripts": {
        "dev": "npm-run-all -p dev:backend dev:frontend",
        "dev:backend": "npm --workspace backend run dev",
        "dev:frontend": "npm --workspace frontend run start",
        "build": "npm-run-all -p build:backend build:frontend",
        "build:backend": "npm --workspace backend run build",
        "build:frontend": "npm --workspace frontend run build"
    },
    "devDependencies": {
        "npm-run-all": "4.1.5"
    }
}
